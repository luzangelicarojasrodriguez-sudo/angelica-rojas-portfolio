---
import { timeline } from '../data/content';
---

<section id="experiencia" class="section-padding relative overflow-hidden" aria-labelledby="timeline-heading">
  <div class="absolute inset-0 -z-10 opacity-[0.015]"
       style="background-image: radial-gradient(circle, rgba(217,119,6,0.5) 1px, transparent 1px); background-size: 32px 32px;" aria-hidden="true"></div>

  <div class="container-custom">
    <!-- Header -->
    <div data-animate class="text-center mb-14 lg:mb-16">
      <span class="section-label justify-center">Trayectoria</span>
      <h2 id="timeline-heading" class="section-heading">Experiencia profesional</h2>
      <p class="section-subheading mx-auto mt-4">
        Más de 15 años construyendo reputación, liderando equipos y transformando la comunicación en un motor de crecimiento.
      </p>
    </div>

    <!-- Timeline -->
    <div class="max-w-3xl mx-auto relative">
      <!-- Vertical gold line -->
      <div class="absolute left-6 md:left-8 top-2 bottom-2 w-px"
           style="background: linear-gradient(to bottom, #D97706, rgba(217,119,6,0.15), transparent);" aria-hidden="true"></div>

      <div class="space-y-8">
        {timeline.map((entry, i) => (
          <article
            data-animate
            style={`transition-delay: ${i * 100}ms;`}
            class="relative pl-16 md:pl-20 group"
          >
            <!-- Gold dot -->
            <div class="absolute left-[18px] md:left-[26px] top-5 w-4 h-4 rounded-full
                         transition-all duration-200"
                 style="background: #0C0A09; border: 2.5px solid #D97706; box-shadow: 0 0 0 4px rgba(12,10,9,0.8), 0 0 12px rgba(217,119,6,0.30);"
                 aria-hidden="true"></div>

            <!-- Period -->
            <span class="inline-block text-xs font-accent font-semibold uppercase tracking-[0.15em] text-gold-500 mb-2">
              {entry.period}
            </span>

            <!-- Card -->
            <div class="glass-card glass-card-hover p-6 lg:p-7">
              <h3 class="font-display font-bold text-xl text-onyx-100 mb-1 group-hover:text-onyx-50 transition-colors duration-200">
                {entry.role}
              </h3>
              <p class="text-sm font-accent font-semibold text-gold-500 mb-3">
                {entry.company}
              </p>
              <p class="text-sm text-onyx-500 leading-relaxed mb-5">
                {entry.description}
              </p>

              <!-- Achievements -->
              <ul class="space-y-2">
                {entry.achievements.map((achievement) => (
                  <li class="flex items-start gap-2.5 text-sm text-onyx-400">
                    <svg class="w-4 h-4 mt-0.5 text-gold-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                    </svg>
                    {achievement}
                  </li>
                ))}
              </ul>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
