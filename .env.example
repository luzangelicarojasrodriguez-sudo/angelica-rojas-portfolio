# ============================================================
# Variables de Entorno — Portafolio Angélica Rojas
# ============================================================
# Copia este archivo como .env y completa los valores.
# El archivo .env NUNCA se sube a GitHub.
# ============================================================

# --- URL del sitio ---
PUBLIC_SITE_URL=https://angelicarojas.com

# --- Correo de contacto ---
PUBLIC_CONTACT_EMAIL=contacto@angelicarojas.com

# --- Servicio de formulario (opcional) ---
# PUBLIC_FORMSPREE_ID=tu_id_de_formspree
# PUBLIC_EMAILJS_SERVICE_ID=tu_service_id
# PUBLIC_EMAILJS_TEMPLATE_ID=tu_template_id
# PUBLIC_EMAILJS_PUBLIC_KEY=tu_public_key

# --- Google Analytics (opcional) ---
# PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================================
# Supabase — https://supabase.com/dashboard
# Settings → API → copia los valores
# ============================================================

# URL pública del proyecto (ej: https://xyzxyzxyz.supabase.co)
PUBLIC_SUPABASE_URL=

# Clave anon/public — segura para usar en el frontend
PUBLIC_SUPABASE_ANON_KEY=

# Clave service_role — SOLO para backend/edge functions, NUNCA en el frontend
# SUPABASE_SERVICE_ROLE_KEY=
