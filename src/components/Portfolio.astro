---
import { portfolio } from '../data/content';

/* Collect unique categories for filter tabs */
const categories = ['Todos', ...new Set(portfolio.map((p) => p.category))];
---

<section id="portafolio" class="section-padding bg-slate-50/50 dark:bg-slate-900/30" aria-labelledby="portfolio-heading">
  <div class="container-custom">
    <!-- Section header -->
    <div data-animate class="text-center mb-14 lg:mb-16">
      <span class="section-label justify-center">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0M12 12.75h.008v.008H12v-.008z" />
        </svg>
        Portafolio
      </span>
      <h2 id="portfolio-heading" class="section-heading">Proyectos destacados</h2>
      <p class="section-subheading mx-auto mt-4">
        Una selección de proyectos estratégicos que reflejan el impacto de una comunicación bien ejecutada.
      </p>
    </div>

    <!-- Filter tabs -->
    <div data-animate class="flex flex-wrap justify-center gap-2 mb-10" role="tablist" aria-label="Filtrar proyectos por categoría">
      {categories.map((cat, i) => (
        <button
          type="button"
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
          data-filter={cat}
          class:list={[
            'portfolio-filter px-4 py-2 rounded-lg text-sm font-medium transition-all duration-200',
            i === 0
              ? 'bg-petrol-700 text-white dark:bg-petrol-600 shadow-md'
              : 'text-slate-600 dark:text-slate-400 hover:bg-slate-200/60 dark:hover:bg-slate-800/60',
          ]}
        >
          {cat}
        </button>
      ))}
    </div>

    <!-- Project grid -->
    <div id="portfolio-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {portfolio.map((project, i) => (
        <article
          data-animate="scale"
          data-category={project.category}
          style={`transition-delay: ${i * 100}ms;`}
          class="portfolio-card glass-card overflow-hidden group hover:shadow-xl hover:shadow-petrol-100/20
                 dark:hover:shadow-petrol-900/20 hover:-translate-y-1 transition-all duration-300"
        >
          <!-- Color accent bar -->
          <div class="h-1 w-full bg-gradient-to-r from-petrol-500 to-petrol-300 dark:from-petrol-600 dark:to-petrol-400
                      scale-x-0 group-hover:scale-x-100 origin-left transition-transform duration-500" aria-hidden="true"></div>

          <!-- Project Image -->
          {project.image && (
            <div class="aspect-video w-full overflow-hidden bg-slate-100 dark:bg-slate-900 relative border-b border-slate-200/50 dark:border-slate-800/50">
              <img 
                src={project.image} 
                alt={project.title} 
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
            </div>
          )}

          <div class="p-6 lg:p-7">
            <!-- Category badge -->
            <span class="inline-block text-[11px] font-semibold uppercase tracking-wider text-petrol-600 dark:text-petrol-400 mb-3">
              {project.category}
            </span>

            <h3 class="font-display font-bold text-lg text-slate-900 dark:text-white mb-3 leading-snug">
              {project.title}
            </h3>

            <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed mb-5">
              {project.description}
            </p>

            <!-- Results -->
            <div class="space-y-2 mb-5">
              {project.results.map((result) => (
                <div class="flex items-start gap-2">
                  <svg class="w-4 h-4 mt-0.5 text-petrol-500 dark:text-petrol-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941" />
                  </svg>
                  <span class="text-sm font-medium text-slate-700 dark:text-slate-300">{result}</span>
                </div>
              ))}
            </div>

            <!-- Tags -->
            <div class="flex flex-wrap gap-1.5 mb-5">
              {project.tags.map((tag) => (
                <span class="px-2.5 py-1 text-[11px] font-medium rounded-md bg-slate-100 dark:bg-slate-800
                             text-slate-600 dark:text-slate-400">
                   {tag}
                </span>
              ))}
            </div>

            <!-- Action Link (PDF Case Study) -->
            {project.pdf && (
              <div class="pt-4 border-t border-slate-100 dark:border-slate-800/80">
                <a
                  href={project.pdf}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 text-xs font-bold text-petrol-700 dark:text-petrol-400
                         hover:text-petrol-800 dark:hover:text-petrol-300 transition-colors duration-200"
                >
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m.75 12h4.5m-4.5 3H12m9-8.25v10.5A2.25 2.25 0 0118.75 21H5.25A2.25 2.25 0 013 18.75V5.25A2.25 2.25 0 015.25 3h7.875c.6 0 1.173.238 1.59.66l4.63 4.63c.423.418.66 1.002.66 1.6v1.442z" />
                  </svg>
                  Ver Caso de Estudio (PDF)
                </a>
              </div>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    var buttons = document.querySelectorAll('.portfolio-filter');
    var cards   = document.querySelectorAll('.portfolio-card');

    buttons.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var filter = btn.getAttribute('data-filter');

        /* Update active button styles */
        buttons.forEach(function (b) {
          b.classList.remove('bg-petrol-700', 'text-white', 'dark:bg-petrol-600', 'shadow-md');
          b.classList.add('text-slate-600', 'dark:text-slate-400');
          b.setAttribute('aria-selected', 'false');
        });
        btn.classList.add('bg-petrol-700', 'text-white', 'dark:bg-petrol-600', 'shadow-md');
        btn.classList.remove('text-slate-600', 'dark:text-slate-400');
        btn.setAttribute('aria-selected', 'true');

        /* Filter cards */
        cards.forEach(function (card) {
          var cat = card.getAttribute('data-category');
          if (filter === 'Todos' || cat === filter) {
            card.style.display = '';
            card.style.opacity = '1';
            card.style.transform = 'scale(1)';
          } else {
            card.style.opacity = '0';
            card.style.transform = 'scale(0.95)';
            setTimeout(function () { card.style.display = 'none'; }, 300);
          }
        });
      });
    });
  })();
</script>
