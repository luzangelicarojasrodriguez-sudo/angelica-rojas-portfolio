---
import { portfolio } from '../data/content';

const categories = ['Todos', ...new Set(portfolio.map((p) => p.category))];

/* Color accent per category */
const categoryColors: Record<string, string> = {
  'Comunicación Corporativa': 'from-blue-900/40 to-onyx-900',
  'Branding':                  'from-purple-900/40 to-onyx-900',
  'Marketing Digital':         'from-emerald-900/40 to-onyx-900',
  'Gestión de Crisis':         'from-red-900/40 to-onyx-900',
  'Producción de Contenidos':  'from-amber-900/40 to-onyx-900',
  'Employer Branding':         'from-sky-900/40 to-onyx-900',
};
---

<section id="portafolio" class="section-padding relative" aria-labelledby="portfolio-heading">
  <div class="absolute top-0 left-0 right-0 h-px divider-gold" aria-hidden="true"></div>
  <div class="absolute inset-0 -z-10" aria-hidden="true"
       style="background: radial-gradient(ellipse 70% 40% at 50% 0%, rgba(217,119,6,0.04), transparent);"></div>

  <div class="container-custom">
    <!-- Header -->
    <div data-animate class="text-center mb-12 lg:mb-14">
      <span class="section-label justify-center">Portafolio</span>
      <h2 id="portfolio-heading" class="section-heading">Proyectos destacados</h2>
      <p class="section-subheading mx-auto mt-4">
        Una selección de proyectos estratégicos que reflejan el impacto de una comunicación bien ejecutada.
      </p>
    </div>

    <!-- Filter tabs -->
    <div data-animate class="flex flex-wrap justify-center gap-2 mb-10" role="tablist" aria-label="Filtrar proyectos por categoría">
      {categories.map((cat, i) => (
        <button
          type="button"
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
          data-filter={cat}
          class:list={[
            'portfolio-filter px-4 py-2 rounded-lg text-xs font-accent font-semibold uppercase tracking-wider transition-all duration-200 cursor-pointer',
            i === 0
              ? 'bg-gold-600 text-onyx-950 shadow-gold-sm'
              : 'text-onyx-500 hover:text-onyx-200',
          ]}
          style={i !== 0 ? 'border: 1px solid rgba(255,255,255,0.08);' : ''}
        >
          {cat}
        </button>
      ))}
    </div>

    <!-- Project grid -->
    <div id="portfolio-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      {portfolio.map((project, i) => (
        <article
          data-animate="scale"
          data-category={project.category}
          style={`transition-delay: ${i * 80}ms;`}
          class="portfolio-card glass-card glass-card-hover overflow-hidden group"
        >
          <!-- Image or color gradient header -->
          <div class={`h-48 relative overflow-hidden bg-gradient-to-br ${categoryColors[project.category] || 'from-onyx-800 to-onyx-900'}`}>
            {project.image ? (
              <img
                src={project.image}
                alt={project.title}
                class="w-full h-full object-cover opacity-60 group-hover:opacity-80 group-hover:scale-105
                       transition-all duration-500"
                loading="lazy"
                width="400" height="192"
              />
            ) : null}
            <!-- Category badge overlay -->
            <div class="absolute top-3 left-3">
              <span class="badge-gold text-[10px]">{project.category}</span>
            </div>
            <!-- Gold accent line on hover -->
            <div class="absolute bottom-0 left-0 right-0 h-0.5 bg-gradient-to-r from-gold-600 to-gold-400
                         scale-x-0 group-hover:scale-x-100 origin-left transition-transform duration-500" aria-hidden="true"></div>
          </div>

          <!-- Content -->
          <div class="p-6">
            <h3 class="font-display font-bold text-xl text-onyx-100 mb-3 leading-snug group-hover:text-onyx-50 transition-colors duration-200">
              {project.title}
            </h3>

            <p class="text-sm text-onyx-500 leading-relaxed mb-5">
              {project.description}
            </p>

            <!-- Results -->
            <div class="space-y-2 mb-5">
              {project.results.map((result) => (
                <div class="flex items-start gap-2">
                  <svg class="w-4 h-4 mt-0.5 text-gold-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941" />
                  </svg>
                  <span class="text-sm font-medium text-onyx-300">{result}</span>
                </div>
              ))}
            </div>

            <!-- Tags -->
            <div class="flex flex-wrap gap-1.5 mb-4">
              {project.tags.map((tag) => (
                <span class="px-2.5 py-1 text-[11px] font-accent font-medium rounded-md text-onyx-500"
                      style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.07);">
                  {tag}
                </span>
              ))}
            </div>

            <!-- PDF link -->
            {project.pdf && (
              <div class="pt-4" style="border-top: 1px solid rgba(255,255,255,0.06);">
                <a
                  href={project.pdf}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 text-xs font-accent font-bold text-gold-500
                         hover:text-gold-400 transition-colors duration-200 cursor-pointer"
                >
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m.75 12h4.5m-4.5 3H12m9-8.25v10.5A2.25 2.25 0 0118.75 21H5.25A2.25 2.25 0 013 18.75V5.25A2.25 2.25 0 015.25 3h7.875c.6 0 1.173.238 1.59.66l4.63 4.63c.423.418.66 1.002.66 1.6v1.442z" />
                  </svg>
                  Ver Caso de Estudio (PDF)
                </a>
              </div>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    var buttons = document.querySelectorAll('.portfolio-filter');
    var cards   = document.querySelectorAll('.portfolio-card');

    buttons.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var filter = btn.getAttribute('data-filter');

        buttons.forEach(function (b) {
          b.classList.remove('bg-gold-600', 'text-onyx-950', 'shadow-gold-sm');
          b.classList.add('text-onyx-500');
          b.setAttribute('aria-selected', 'false');
        });
        btn.classList.add('bg-gold-600', 'text-onyx-950', 'shadow-gold-sm');
        btn.classList.remove('text-onyx-500');
        btn.setAttribute('aria-selected', 'true');

        cards.forEach(function (card) {
          var cat = card.getAttribute('data-category');
          if (filter === 'Todos' || cat === filter) {
            card.style.display   = '';
            card.style.opacity   = '1';
            card.style.transform = '';
          } else {
            card.style.opacity   = '0';
            card.style.transform = 'scale(0.95)';
            setTimeout(function () { if (card.style.opacity === '0') card.style.display = 'none'; }, 280);
          }
        });
      });
    });
  })();
</script>
