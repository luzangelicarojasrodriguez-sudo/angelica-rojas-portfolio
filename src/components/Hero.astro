---
import { hero } from '../data/content';
---

<section id="inicio" class="relative overflow-hidden section-padding pt-16 md:pt-24 lg:pt-32 noise-overlay" aria-labelledby="hero-heading">

  <!-- Ambient gradient blobs -->
  <div class="absolute inset-0 -z-10 overflow-hidden" aria-hidden="true">
    <!-- Primary gold blob -->
    <div class="absolute -top-32 -right-32 w-[600px] h-[600px] rounded-full opacity-[0.07] blur-[100px] animate-pulse-soft"
         style="background: radial-gradient(circle, #F59E0B 0%, #D97706 50%, transparent 70%);"></div>
    <!-- Secondary warm blob -->
    <div class="absolute -bottom-48 -left-24 w-[500px] h-[500px] rounded-full opacity-[0.06] blur-[90px] animate-pulse-soft"
         style="background: radial-gradient(circle, #D97706 0%, #92400E 60%, transparent 80%); animation-delay: 2s;"></div>
    <!-- Subtle center glow -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[400px] rounded-full opacity-[0.03] blur-[120px]"
         style="background: radial-gradient(ellipse, #FCD34D, transparent 70%);"></div>
    <!-- Dot grid -->
    <div class="absolute inset-0 opacity-[0.035]"
         style="background-image: radial-gradient(circle, rgba(217,119,6,0.6) 1px, transparent 1px); background-size: 40px 40px;"></div>
  </div>

  <div class="container-custom">
    <div class="max-w-4xl mx-auto text-center">

      <!-- Badge -->
      <div data-animate class="mb-8">
        <span class="badge-gold">
          <span class="w-1.5 h-1.5 rounded-full bg-gold-400 animate-pulse-soft"></span>
          Comunicación Estratégica · Branding · Reputación
        </span>
      </div>

      <!-- Main headline — Cormorant Garamond editorial -->
      <h1
        id="hero-heading"
        data-animate
        class="font-display font-bold text-5xl sm:text-6xl md:text-6.5xl lg:text-7.5xl
               text-onyx-50 leading-[1.05] tracking-tight mb-8"
        style="transition-delay: 80ms;"
      >
        {hero.headline}
      </h1>

      <!-- Sub-headline -->
      <p
        data-animate
        class="text-lg sm:text-xl text-onyx-400 leading-relaxed max-w-2xl mx-auto mb-12"
        style="transition-delay: 160ms;"
      >
        {hero.subheadline}
      </p>

      <!-- CTAs -->
      <div data-animate class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-20" style="transition-delay: 240ms;">
        <a href={hero.cta.primary.href} class="btn-primary w-full sm:w-auto text-base px-8 py-4">
          {hero.cta.primary.label}
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
        <a href={hero.cta.secondary.href} class="btn-secondary w-full sm:w-auto text-base px-8 py-4">
          {hero.cta.secondary.label}
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3" />
          </svg>
        </a>
      </div>

      <!-- Divider line -->
      <div data-animate class="divider-gold mb-12" style="transition-delay: 300ms;"></div>

      <!-- Stats -->
      <div data-animate class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-6" style="transition-delay: 360ms;">
        {hero.stats.map((stat, i) => (
          <div class="text-center group cursor-default" style={`transition-delay: ${360 + i * 60}ms;`}>
            <p class="font-display font-bold text-4xl sm:text-5xl gradient-text mb-2
                       transition-transform duration-200 group-hover:scale-105">
              {stat.value}
            </p>
            <p class="text-xs sm:text-sm text-onyx-500 font-accent font-medium uppercase tracking-wider">
              {stat.label}
            </p>
          </div>
        ))}
      </div>

    </div>
  </div>

  <!-- Bottom gradient fade -->
  <div class="absolute bottom-0 left-0 right-0 h-32 pointer-events-none" aria-hidden="true"
       style="background: linear-gradient(to top, #0C0A09, transparent);"></div>
</section>
