---
import { navigation, siteConfig } from '../data/content';
import ThemeToggle from './ThemeToggle.astro';
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" role="banner">
  <nav class="container-custom flex items-center justify-between h-16 lg:h-20" aria-label="Navegación principal">
    <!-- Logo / Name -->
    <a
      href="#inicio"
      class="font-display font-bold text-lg sm:text-xl tracking-tight text-slate-900 dark:text-white
             hover:text-petrol-700 dark:hover:text-petrol-400 transition-colors duration-200"
    >
      {siteConfig.name}<span class="text-petrol-600 dark:text-petrol-400">.</span>
    </a>

    <!-- Desktop navigation -->
    <div class="hidden lg:flex items-center gap-1">
      {navigation.map((item) => (
        <a
          href={item.href}
          class="px-4 py-2 text-sm font-medium text-slate-600 dark:text-slate-400
                 hover:text-petrol-700 dark:hover:text-petrol-300 rounded-lg
                 hover:bg-slate-100/60 dark:hover:bg-slate-800/60 transition-all duration-200"
        >
          {item.label}
        </a>
      ))}
      <div class="ml-2 pl-2 border-l border-slate-200 dark:border-slate-700">
        <ThemeToggle />
      </div>
    </div>

    <!-- Mobile controls -->
    <div class="flex items-center gap-2 lg:hidden">
      <ThemeToggle />
      <button
        id="mobile-menu-toggle"
        type="button"
        class="p-2 rounded-lg text-slate-600 dark:text-slate-400
               hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors duration-200"
        aria-label="Abrir menú de navegación"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path id="hamburger-path" stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu overlay -->
  <div
    id="mobile-menu"
    class="hidden lg:hidden bg-white/95 dark:bg-slate-950/95 backdrop-blur-2xl
           border-t border-slate-200/60 dark:border-slate-800/60"
    role="menu"
  >
    <div class="container-custom py-6 flex flex-col gap-1">
      {navigation.map((item) => (
        <a
          href={item.href}
          class="mobile-nav-link px-4 py-3 text-base font-medium rounded-xl
                 text-slate-700 dark:text-slate-300
                 hover:text-petrol-700 dark:hover:text-petrol-300
                 hover:bg-slate-100/70 dark:hover:bg-slate-800/50
                 transition-all duration-200"
          role="menuitem"
        >
          {item.label}
        </a>
      ))}
    </div>
  </div>
</header>

<!-- Spacer so content doesn't hide behind fixed header -->
<div class="h-16 lg:h-20" aria-hidden="true"></div>

<script is:inline>
  (function () {
    var header = document.getElementById('site-header');
    var toggle = document.getElementById('mobile-menu-toggle');
    var menu   = document.getElementById('mobile-menu');
    var path   = document.getElementById('hamburger-path');
    var links  = document.querySelectorAll('.mobile-nav-link');

    var OPEN_D  = 'M6 18L18 6M6 6l12 12';
    var CLOSE_D = 'M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5';

    /* Scroll: add glass background + shadow */
    window.addEventListener('scroll', function () {
      if (window.scrollY > 24) {
        header.classList.add('bg-white/80', 'dark:bg-slate-950/80', 'backdrop-blur-2xl',
          'shadow-sm', 'shadow-slate-900/5', 'dark:shadow-black/20');
      } else {
        header.classList.remove('bg-white/80', 'dark:bg-slate-950/80', 'backdrop-blur-2xl',
          'shadow-sm', 'shadow-slate-900/5', 'dark:shadow-black/20');
      }
    }, { passive: true });

    /* Mobile menu toggle */
    function closeMenu() {
      menu.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
      path.setAttribute('d', CLOSE_D);
    }

    toggle.addEventListener('click', function () {
      var isOpen = !menu.classList.contains('hidden');
      if (isOpen) {
        closeMenu();
      } else {
        menu.classList.remove('hidden');
        toggle.setAttribute('aria-expanded', 'true');
        path.setAttribute('d', OPEN_D);
      }
    });

    links.forEach(function (link) {
      link.addEventListener('click', closeMenu);
    });
  })();
</script>
