---
import { skills } from '../data/content';

const categoryMeta: Record<string, { label: string; style: string }> = {
  strategic:  { label: 'Estrategia',               style: 'rgba(99,102,241,0.12)' },
  creative:   { label: 'Creatividad',              style: 'rgba(168,85,247,0.12)' },
  digital:    { label: 'Digital & Marketing',      style: 'rgba(16,185,129,0.12)' },
  tools:      { label: 'Herramientas & Plataformas', style: 'rgba(217,119,6,0.12)' },
  leadership: { label: 'Liderazgo & Gestión',      style: 'rgba(244,63,94,0.12)' },
};
---

<section id="habilidades" class="section-padding relative overflow-hidden" aria-labelledby="skills-heading">
  <div class="absolute top-0 left-0 right-0 h-px divider-gold" aria-hidden="true"></div>

  <div class="container-custom">
    <!-- Header -->
    <div data-animate class="text-center mb-14 lg:mb-16">
      <span class="section-label justify-center">Competencias</span>
      <h2 id="skills-heading" class="section-heading">Habilidades y herramientas</h2>
      <p class="section-subheading mx-auto mt-4">
        Un conjunto diverso de competencias estratégicas, creativas y digitales desarrolladas a lo largo de más de 15 años de carrera.
      </p>
    </div>

    <!-- Skill categories grid -->
    <div class="grid md:grid-cols-2 gap-5 max-w-5xl mx-auto">
      {Object.entries(skills).map(([key, items], i) => {
        const meta = categoryMeta[key];
        return (
          <div
            data-animate
            style={`transition-delay: ${i * 80}ms;`}
            class:list={['glass-card p-6 lg:p-8', i === 4 ? 'md:col-span-2' : '']}
          >
            <!-- Category header -->
            <div class="flex items-center gap-3 mb-5">
              <div class="w-2 h-2 rounded-full bg-gold-500 flex-shrink-0"></div>
              <h3 class="font-accent font-semibold text-sm uppercase tracking-[0.15em] text-gold-500">
                {meta?.label || key}
              </h3>
            </div>

            <!-- Skills pills -->
            <div class="flex flex-wrap gap-2">
              {(items as string[]).map((skill: string, j: number) => (
                <span
                  class="px-3 py-1.5 text-sm font-accent text-onyx-300 rounded-lg
                         transition-all duration-200 cursor-default"
                  style={`background: ${meta?.style || 'rgba(255,255,255,0.05)'}; border: 1px solid rgba(255,255,255,0.08); transition-delay: ${j * 20}ms;`}
                >
                  {skill}
                </span>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
