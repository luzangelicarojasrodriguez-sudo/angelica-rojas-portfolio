---
import { skills } from '../data/content';

/** Display metadata for each skill category */
const categoryMeta: Record<string, { label: string; color: string; darkColor: string }> = {
  strategic:  { label: 'Estrategia',            color: 'bg-blue-50 text-blue-700 border-blue-200/60',      darkColor: 'dark:bg-blue-950/40 dark:text-blue-300 dark:border-blue-800/40' },
  creative:   { label: 'Creatividad',           color: 'bg-violet-50 text-violet-700 border-violet-200/60', darkColor: 'dark:bg-violet-950/40 dark:text-violet-300 dark:border-violet-800/40' },
  digital:    { label: 'Digital & Marketing',    color: 'bg-emerald-50 text-emerald-700 border-emerald-200/60', darkColor: 'dark:bg-emerald-950/40 dark:text-emerald-300 dark:border-emerald-800/40' },
  tools:      { label: 'Herramientas & Plataformas', color: 'bg-amber-50 text-amber-700 border-amber-200/60', darkColor: 'dark:bg-amber-950/40 dark:text-amber-300 dark:border-amber-800/40' },
  leadership: { label: 'Liderazgo & Gestión',   color: 'bg-rose-50 text-rose-700 border-rose-200/60',      darkColor: 'dark:bg-rose-950/40 dark:text-rose-300 dark:border-rose-800/40' },
};
---

<section id="habilidades" class="section-padding" aria-labelledby="skills-heading">
  <div class="container-custom">
    <!-- Section header -->
    <div data-animate class="text-center mb-14 lg:mb-16">
      <span class="section-label justify-center">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17l-5.1-3.054A2.063 2.063 0 015.25 10.3V8.758a2.063 2.063 0 01.805-1.63l5.1-3.054a2.063 2.063 0 012.09 0l5.1 3.054a2.063 2.063 0 01.805 1.63v1.542a2.063 2.063 0 01-.805 1.63l-5.1 3.054a2.063 2.063 0 01-2.09 0z" />
        </svg>
        Competencias
      </span>
      <h2 id="skills-heading" class="section-heading">Habilidades y herramientas</h2>
      <p class="section-subheading mx-auto mt-4">
        Un conjunto diverso de competencias estratégicas, creativas y digitales desarrolladas a lo largo de más de 15 años de carrera profesional.
      </p>
    </div>

    <!-- Skill categories -->
    <div class="space-y-8 max-w-4xl mx-auto">
      {Object.entries(skills).map(([key, items], i) => {
        const meta = categoryMeta[key];
        return (
          <div
            data-animate
            style={`transition-delay: ${i * 100}ms;`}
            class="glass-card p-6 lg:p-7"
          >
            <h3 class="font-display font-bold text-base text-slate-900 dark:text-white mb-4">
              {meta?.label || key}
            </h3>
            <div class="flex flex-wrap gap-2">
              {items.map((skill: string) => (
                <span class:list={[
                  'px-3 py-1.5 text-sm font-medium rounded-lg border transition-all duration-200 hover:-translate-y-0.5',
                  meta?.color || 'bg-slate-100 text-slate-700 border-slate-200',
                  meta?.darkColor || 'dark:bg-slate-800 dark:text-slate-300 dark:border-slate-700',
                ]}>
                  {skill}
                </span>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
