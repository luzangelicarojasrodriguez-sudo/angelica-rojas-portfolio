---
import { successStories } from '../data/content';
---

<section id="resultados" class="section-padding" aria-labelledby="success-heading">
  <div class="container-custom">
    <!-- Section header -->
    <div data-animate class="text-center mb-14 lg:mb-16">
      <span class="section-label justify-center">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941" />
        </svg>
        Resultados
      </span>
      <h2 id="success-heading" class="section-heading">Casos de éxito con impacto medible</h2>
      <p class="section-subheading mx-auto mt-4">
        Resultados cuantificables que demuestran el poder de una comunicación estratégica bien ejecutada.
      </p>
    </div>

    <!-- Success stories grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {successStories.map((story, i) => (
        <article
          data-animate="scale"
          style={`transition-delay: ${i * 100}ms;`}
          class="glass-card p-7 text-center group hover:border-petrol-300/60 dark:hover:border-petrol-600/40
                 hover:shadow-xl hover:shadow-petrol-100/20 dark:hover:shadow-petrol-900/20
                 hover:-translate-y-1 transition-all duration-300"
        >
          <!-- Big metric -->
          <p class="font-display font-extrabold text-4xl lg:text-5xl gradient-text mb-2
                    group-hover:scale-110 transition-transform duration-300">
            {story.metric}
          </p>

          <!-- Title -->
          <h3 class="font-display font-bold text-base text-slate-900 dark:text-white mb-3">
            {story.title}
          </h3>

          <!-- Description -->
          <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed mb-4">
            {story.description}
          </p>

          <!-- Context badge -->
          <span class="inline-block text-[11px] font-semibold uppercase tracking-wider
                       text-petrol-600 dark:text-petrol-400 px-3 py-1 rounded-full
                       bg-petrol-50 dark:bg-petrol-900/40 border border-petrol-200/50 dark:border-petrol-700/30">
            {story.context}
          </span>
        </article>
      ))}
    </div>
  </div>
</section>
