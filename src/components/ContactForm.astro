---
import { contact, siteConfig } from '../data/content';
---

<section id="contacto" class="section-padding relative overflow-hidden" aria-labelledby="contact-heading">
  <div class="absolute top-0 left-0 right-0 h-px divider-gold" aria-hidden="true"></div>

  <div class="container-custom">
    <div class="max-w-5xl mx-auto">
      <!-- Header -->
      <div data-animate class="text-center mb-14 lg:mb-16">
        <span class="section-label justify-center">Contacto</span>
        <h2 id="contact-heading" class="section-heading">{contact.headline}</h2>
        <p class="section-subheading mx-auto mt-4">{contact.description}</p>
      </div>

      <div class="grid lg:grid-cols-5 gap-10 lg:gap-12">

        <!-- Left: Contact info -->
        <div class="lg:col-span-2 space-y-4" data-animate="slide-left">
          {[
            {
              href: `mailto:${siteConfig.email}`,
              label: 'Email',
              value: siteConfig.email,
              icon: 'M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75',
              isLink: true,
            },
            {
              href: `tel:${siteConfig.phone}`,
              label: 'Teléfono',
              value: siteConfig.phone,
              icon: 'M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z',
              isLink: true,
            },
            {
              href: null,
              label: 'Ubicación',
              value: siteConfig.location,
              icon: 'M15 10.5a3 3 0 11-6 0 3 3 0 016 0zM19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z',
              isLink: false,
            },
          ].map((info) => {
            const Tag = info.isLink ? 'a' : 'div';
            return (
              <Tag
                href={info.href || undefined}
                class="glass-card glass-card-hover p-5 flex items-center gap-4 group"
                style={info.isLink ? 'cursor: pointer;' : ''}
              >
                <div class="w-11 h-11 rounded-xl flex items-center justify-center flex-shrink-0 transition-all duration-200"
                     style="background: rgba(217,119,6,0.10); border: 1px solid rgba(217,119,6,0.20);">
                  <svg class="w-5 h-5 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d={info.icon} />
                  </svg>
                </div>
                <div>
                  <p class="text-[11px] text-onyx-500 font-accent uppercase tracking-wider mb-0.5">{info.label}</p>
                  <p class="text-sm font-accent font-semibold text-onyx-100 group-hover:text-gold-400 transition-colors duration-200">{info.value}</p>
                </div>
              </Tag>
            );
          })}

          <!-- Availability note -->
          <div class="glass-card p-5 flex items-start gap-3 mt-2">
            <span class="w-2 h-2 rounded-full bg-emerald-400 mt-1.5 flex-shrink-0 animate-pulse"></span>
            <div>
              <p class="text-sm font-accent font-semibold text-onyx-100 mb-1">Disponible para proyectos</p>
              <p class="text-xs text-onyx-500 leading-relaxed">
                Actualmente acepto nuevos proyectos de consultoría estratégica, branding y comunicación corporativa.
              </p>
            </div>
          </div>
        </div>

        <!-- Right: Form -->
        <div class="lg:col-span-3" data-animate="slide-right">
          <form id="contact-form" class="glass-card p-7 lg:p-9 space-y-5" novalidate>

            <div class="grid sm:grid-cols-2 gap-5">
              <!-- Name -->
              <div>
                <label for="contact-name" class="block text-xs font-accent font-semibold uppercase tracking-[0.12em] text-onyx-400 mb-2">
                  Nombre completo <span class="text-gold-500" aria-hidden="true">*</span>
                </label>
                <input
                  type="text"
                  id="contact-name"
                  name="name"
                  required
                  autocomplete="name"
                  placeholder="Tu nombre"
                  class="contact-input w-full px-4 py-3 rounded-xl text-sm text-onyx-100 placeholder-onyx-700
                         transition-all duration-200 outline-none"
                  style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.10);"
                />
              </div>
              <!-- Email -->
              <div>
                <label for="contact-email" class="block text-xs font-accent font-semibold uppercase tracking-[0.12em] text-onyx-400 mb-2">
                  Correo electrónico <span class="text-gold-500" aria-hidden="true">*</span>
                </label>
                <input
                  type="email"
                  id="contact-email"
                  name="email"
                  required
                  autocomplete="email"
                  placeholder="tu@email.com"
                  class="contact-input w-full px-4 py-3 rounded-xl text-sm text-onyx-100 placeholder-onyx-700
                         transition-all duration-200 outline-none"
                  style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.10);"
                />
              </div>
            </div>

            <!-- Subject -->
            <div>
              <label for="contact-subject" class="block text-xs font-accent font-semibold uppercase tracking-[0.12em] text-onyx-400 mb-2">
                Asunto
              </label>
              <input
                type="text"
                id="contact-subject"
                name="subject"
                placeholder="¿En qué puedo ayudarte?"
                class="contact-input w-full px-4 py-3 rounded-xl text-sm text-onyx-100 placeholder-onyx-700
                       transition-all duration-200 outline-none"
                style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.10);"
              />
            </div>

            <!-- Message -->
            <div>
              <label for="contact-message" class="block text-xs font-accent font-semibold uppercase tracking-[0.12em] text-onyx-400 mb-2">
                Mensaje <span class="text-gold-500" aria-hidden="true">*</span>
              </label>
              <textarea
                id="contact-message"
                name="message"
                required
                rows="5"
                placeholder="Cuéntame sobre tu proyecto o necesidad…"
                class="contact-input w-full px-4 py-3 rounded-xl text-sm text-onyx-100 placeholder-onyx-700
                       transition-all duration-200 outline-none resize-y"
                style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.10);"
              ></textarea>
            </div>

            <!-- Submit -->
            <button type="submit" id="contact-submit" class="btn-primary w-full sm:w-auto">
              <span id="submit-label">Enviar mensaje</span>
              <svg id="submit-icon" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
              </svg>
            </button>

            <!-- Status alerts -->
            <div id="form-success" class="hidden p-4 rounded-xl" role="alert"
                 style="background: rgba(16,185,129,0.10); border: 1px solid rgba(16,185,129,0.25);">
              <p class="text-sm font-accent font-medium text-emerald-400">
                ¡Mensaje enviado con éxito! Te responderé a la brevedad.
              </p>
            </div>
            <div id="form-error" class="hidden p-4 rounded-xl" role="alert"
                 style="background: rgba(244,63,94,0.10); border: 1px solid rgba(244,63,94,0.20);">
              <p id="form-error-msg" class="text-sm font-accent font-medium text-rose-400">
                Por favor completa todos los campos requeridos correctamente.
              </p>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-input:focus {
    border-color: rgba(217,119,6,0.50) !important;
    box-shadow: 0 0 0 3px rgba(217,119,6,0.10);
    background: rgba(255,255,255,0.06) !important;
  }
  .contact-input::placeholder {
    color: rgba(168,162,158,0.5);
  }
</style>

<script>
  import { supabase } from '../lib/supabase';

  const form    = document.getElementById('contact-form')    as HTMLFormElement | null;
  const success = document.getElementById('form-success')    as HTMLElement | null;
  const errorEl = document.getElementById('form-error')      as HTMLElement | null;
  const errorMsg = document.getElementById('form-error-msg') as HTMLElement | null;
  const submit  = document.getElementById('contact-submit')  as HTMLButtonElement | null;
  const label   = document.getElementById('submit-label')    as HTMLElement | null;

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      success?.classList.add('hidden');
      errorEl?.classList.add('hidden');

      const name    = (form.querySelector('#contact-name')    as HTMLInputElement).value.trim();
      const email   = (form.querySelector('#contact-email')   as HTMLInputElement).value.trim();
      const subject = (form.querySelector('#contact-subject') as HTMLInputElement).value.trim();
      const message = (form.querySelector('#contact-message') as HTMLTextAreaElement).value.trim();

      const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!name || !email || !message || !emailPattern.test(email)) {
        if (errorMsg) errorMsg.textContent = 'Por favor completa todos los campos requeridos correctamente.';
        errorEl?.classList.remove('hidden');
        errorEl?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        return;
      }

      /* Loading state */
      if (submit) submit.disabled = true;
      if (label)  label.textContent = 'Enviando…';

      /* ── Guardar en Supabase ── */
      const { error } = await supabase
        .from('contacts')
        .insert([{ name, email, subject, message }]);

      if (submit) submit.disabled = false;
      if (label)  label.textContent = 'Enviar mensaje';

      if (error) {
        console.error('Supabase error:', error.message);
        if (errorMsg) errorMsg.textContent = 'Hubo un problema al enviar. Por favor intenta de nuevo.';
        errorEl?.classList.remove('hidden');
        errorEl?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      } else {
        success?.classList.remove('hidden');
        success?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        form.reset();
      }
    });
  }
</script>
