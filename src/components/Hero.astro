---
import { hero } from '../data/content';
---

<section id="inicio" class="relative overflow-hidden section-padding pt-12 md:pt-20 lg:pt-28" aria-labelledby="hero-heading">
  <!-- Decorative gradient blobs -->
  <div class="absolute inset-0 -z-10 overflow-hidden" aria-hidden="true">
    <div class="absolute -top-40 -right-40 w-[500px] h-[500px] rounded-full bg-petrol-200/30 dark:bg-petrol-900/20 blur-3xl animate-pulse-soft"></div>
    <div class="absolute -bottom-40 -left-40 w-[400px] h-[400px] rounded-full bg-petrol-100/40 dark:bg-petrol-950/30 blur-3xl animate-pulse-soft" style="animation-delay: 1.5s;"></div>
    <!-- Subtle dot grid pattern -->
    <div class="absolute inset-0 opacity-[0.03] dark:opacity-[0.05]" style="background-image: radial-gradient(circle, currentColor 1px, transparent 1px); background-size: 32px 32px;"></div>
  </div>

  <div class="container-custom">
    <div class="max-w-4xl mx-auto text-center">
      <!-- Label badge -->
      <div data-animate class="mb-6">
        <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-accent font-semibold uppercase tracking-[0.15em]
                     bg-petrol-50 dark:bg-petrol-950/50 text-petrol-700 dark:text-petrol-400 border border-petrol-200/60 dark:border-petrol-800/40">
          <span class="w-1.5 h-1.5 rounded-full bg-petrol-500 animate-pulse-soft"></span>
          Comunicación Estratégica · Branding · Reputación
        </span>
      </div>

      <!-- Main headline -->
      <h1
        id="hero-heading"
        data-animate
        class="font-display font-extrabold text-4xl sm:text-5xl md:text-5.5xl lg:text-6.5xl
               text-slate-900 dark:text-white leading-[1.1] tracking-tight mb-6"
        style="transition-delay: 100ms;"
      >
        {hero.headline}
      </h1>

      <!-- Sub-headline -->
      <p
        data-animate
        class="text-lg sm:text-xl text-slate-500 dark:text-slate-400 leading-relaxed max-w-2xl mx-auto mb-10"
        style="transition-delay: 200ms;"
      >
        {hero.subheadline}
      </p>

      <!-- CTAs -->
      <div data-animate class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16 sm:mb-20" style="transition-delay: 300ms;">
        <a href={hero.cta.primary.href} class="btn-primary w-full sm:w-auto">
          {hero.cta.primary.label}
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3" />
          </svg>
        </a>
        <a href={hero.cta.secondary.href} class="btn-secondary w-full sm:w-auto">
          {hero.cta.secondary.label}
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>

      <!-- Stats -->
      <div data-animate class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8" style="transition-delay: 400ms;">
        {hero.stats.map((stat) => (
          <div class="text-center group">
            <p class="font-display font-extrabold text-3xl sm:text-4xl gradient-text mb-1 group-hover:scale-105 transition-transform duration-300">
              {stat.value}
            </p>
            <p class="text-xs sm:text-sm text-slate-500 dark:text-slate-400 font-medium">
              {stat.label}
            </p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Bottom fade-out gradient -->
  <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-white dark:from-slate-950 to-transparent" aria-hidden="true"></div>
</section>
