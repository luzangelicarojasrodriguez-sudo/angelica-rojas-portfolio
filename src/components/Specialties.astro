---

<section id="especialidades" class="section-padding" aria-labelledby="specialties-heading">
  <div class="container-custom">
    <!-- Section header -->
    <div data-animate class="text-center mb-14 lg:mb-16">
      <span class="section-label justify-center">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
        </svg>
        Áreas de Expertise
      </span>
      <h2 id="specialties-heading" class="section-heading">Especialidades que generan impacto</h2>
      <p class="section-subheading mx-auto mt-4">
        Cada servicio combina pensamiento estratégico, experiencia práctica y un enfoque orientado a resultados medibles.
      </p>
    </div>

    <!-- Specialties grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {specialties.map((specialty, i) => (
        <article
          data-animate="scale"
          style={`transition-delay: ${i * 80}ms;`}
          class="glass-card p-6 lg:p-7 group hover:border-petrol-300/60 dark:hover:border-petrol-600/40
                 hover:shadow-lg hover:shadow-petrol-100/30 dark:hover:shadow-petrol-900/20
                 transition-all duration-300 hover:-translate-y-1"
        >
          <!-- Icon -->
          <div class="w-10 h-10 rounded-xl bg-petrol-50 dark:bg-petrol-900/40 flex items-center justify-center mb-4
                      group-hover:bg-petrol-100 dark:group-hover:bg-petrol-800/50 transition-colors duration-300">
            <svg class="w-5 h-5 text-petrol-600 dark:text-petrol-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[specialty.icon] || iconPaths.strategy} />
            </svg>
          </div>
          <h3 class="font-display font-bold text-base text-slate-900 dark:text-white mb-2">
            {specialty.title}
          </h3>
          <p class="text-sm leading-relaxed text-slate-500 dark:text-slate-400">
            {specialty.description}
          </p>
        </article>
      ))}
    </div>
  </div>
</section>
