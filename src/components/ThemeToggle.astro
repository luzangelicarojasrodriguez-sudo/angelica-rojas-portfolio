---
/**
 * ThemeToggle — Accessible dark/light mode switch with animated icon.
 * Persists choice in localStorage and respects system preference as default.
 */
---

<button
  id="theme-toggle"
  type="button"
  aria-label="Cambiar tema de color"
  class="relative p-2 rounded-lg text-slate-500 dark:text-slate-400
         hover:text-petrol-600 dark:hover:text-petrol-400
         hover:bg-slate-100 dark:hover:bg-slate-800
         transition-all duration-200 focus-visible:outline-2 focus-visible:outline-petrol-500"
>
  <!-- Sun icon (shown in dark mode) -->
  <svg
    id="icon-sun"
    class="hidden dark:block w-5 h-5 transition-transform duration-300"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="1.5"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"
    ></path>
  </svg>
  <!-- Moon icon (shown in light mode) -->
  <svg
    id="icon-moon"
    class="block dark:hidden w-5 h-5 transition-transform duration-300"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="1.5"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z"
    ></path>
  </svg>
</button>

<script is:inline>
  (function () {
    var btn = document.getElementById('theme-toggle');
    if (!btn) return;

    btn.addEventListener('click', function () {
      var isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    });
  })();
</script>
