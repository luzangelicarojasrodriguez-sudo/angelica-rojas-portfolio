---
import { contact, siteConfig } from '../data/content';
---

<section id="contacto" class="section-padding" aria-labelledby="contact-heading">
  <div class="container-custom">
    <div class="max-w-5xl mx-auto">
      <!-- Section header -->
      <div data-animate class="text-center mb-14 lg:mb-16">
        <span class="section-label justify-center">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
          Contacto
        </span>
        <h2 id="contact-heading" class="section-heading">{contact.headline}</h2>
        <p class="section-subheading mx-auto mt-4">{contact.description}</p>
      </div>

      <div class="grid lg:grid-cols-5 gap-10 lg:gap-12">
        <!-- Left: Contact info -->
        <div class="lg:col-span-2 space-y-6" data-animate="slide-left">
          <!-- Email -->
          <a href={`mailto:${siteConfig.email}`}
             class="glass-card p-5 flex items-center gap-4 group hover:border-petrol-300/60 dark:hover:border-petrol-600/40
                    hover:shadow-lg transition-all duration-300">
            <div class="w-10 h-10 rounded-xl bg-petrol-50 dark:bg-petrol-900/40 flex items-center justify-center flex-shrink-0
                        group-hover:bg-petrol-100 dark:group-hover:bg-petrol-800/50 transition-colors">
              <svg class="w-5 h-5 text-petrol-600 dark:text-petrol-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
            </div>
            <div>
              <p class="text-xs text-slate-500 dark:text-slate-400 mb-0.5">Email</p>
              <p class="text-sm font-semibold text-slate-900 dark:text-white">{siteConfig.email}</p>
            </div>
          </a>

          <!-- Phone -->
          <a href={`tel:${siteConfig.phone}`}
             class="glass-card p-5 flex items-center gap-4 group hover:border-petrol-300/60 dark:hover:border-petrol-600/40
                    hover:shadow-lg transition-all duration-300">
            <div class="w-10 h-10 rounded-xl bg-petrol-50 dark:bg-petrol-900/40 flex items-center justify-center flex-shrink-0
                        group-hover:bg-petrol-100 dark:group-hover:bg-petrol-800/50 transition-colors">
              <svg class="w-5 h-5 text-petrol-600 dark:text-petrol-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
            </div>
            <div>
              <p class="text-xs text-slate-500 dark:text-slate-400 mb-0.5">Teléfono</p>
              <p class="text-sm font-semibold text-slate-900 dark:text-white">{siteConfig.phone}</p>
            </div>
          </a>

          <!-- Location -->
          <div class="glass-card p-5 flex items-center gap-4">
            <div class="w-10 h-10 rounded-xl bg-petrol-50 dark:bg-petrol-900/40 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-petrol-600 dark:text-petrol-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              </svg>
            </div>
            <div>
              <p class="text-xs text-slate-500 dark:text-slate-400 mb-0.5">Ubicación</p>
              <p class="text-sm font-semibold text-slate-900 dark:text-white">{siteConfig.location}</p>
            </div>
          </div>
        </div>

        <!-- Right: Contact form -->
        <div class="lg:col-span-3" data-animate="slide-right">
          <form id="contact-form" class="glass-card p-6 lg:p-8 space-y-5" novalidate>
            <div class="grid sm:grid-cols-2 gap-5">
              <!-- Name -->
              <div>
                <label for="contact-name" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">
                  Nombre completo <span class="text-rose-500" aria-hidden="true">*</span>
                </label>
                <input
                  type="text"
                  id="contact-name"
                  name="name"
                  required
                  autocomplete="name"
                  placeholder="Tu nombre"
                  class="w-full px-4 py-3 rounded-xl text-sm bg-white dark:bg-slate-900
                         border border-slate-200 dark:border-slate-700
                         text-slate-900 dark:text-white placeholder:text-slate-400 dark:placeholder:text-slate-500
                         focus:border-petrol-500 dark:focus:border-petrol-400 focus:ring-2 focus:ring-petrol-500/20
                         transition-all duration-200 outline-none"
                />
              </div>
              <!-- Email -->
              <div>
                <label for="contact-email" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">
                  Correo electrónico <span class="text-rose-500" aria-hidden="true">*</span>
                </label>
                <input
                  type="email"
                  id="contact-email"
                  name="email"
                  required
                  autocomplete="email"
                  placeholder="tu@email.com"
                  class="w-full px-4 py-3 rounded-xl text-sm bg-white dark:bg-slate-900
                         border border-slate-200 dark:border-slate-700
                         text-slate-900 dark:text-white placeholder:text-slate-400 dark:placeholder:text-slate-500
                         focus:border-petrol-500 dark:focus:border-petrol-400 focus:ring-2 focus:ring-petrol-500/20
                         transition-all duration-200 outline-none"
                />
              </div>
            </div>

            <!-- Subject -->
            <div>
              <label for="contact-subject" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">
                Asunto
              </label>
              <input
                type="text"
                id="contact-subject"
                name="subject"
                placeholder="¿En qué puedo ayudarte?"
                class="w-full px-4 py-3 rounded-xl text-sm bg-white dark:bg-slate-900
                       border border-slate-200 dark:border-slate-700
                       text-slate-900 dark:text-white placeholder:text-slate-400 dark:placeholder:text-slate-500
                       focus:border-petrol-500 dark:focus:border-petrol-400 focus:ring-2 focus:ring-petrol-500/20
                       transition-all duration-200 outline-none"
              />
            </div>

            <!-- Message -->
            <div>
              <label for="contact-message" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">
                Mensaje <span class="text-rose-500" aria-hidden="true">*</span>
              </label>
              <textarea
                id="contact-message"
                name="message"
                required
                rows="5"
                placeholder="Cuéntame sobre tu proyecto o necesidad…"
                class="w-full px-4 py-3 rounded-xl text-sm bg-white dark:bg-slate-900
                       border border-slate-200 dark:border-slate-700
                       text-slate-900 dark:text-white placeholder:text-slate-400 dark:placeholder:text-slate-500
                       focus:border-petrol-500 dark:focus:border-petrol-400 focus:ring-2 focus:ring-petrol-500/20
                       transition-all duration-200 outline-none resize-y"
              ></textarea>
            </div>

            <!-- Submit -->
            <button type="submit" class="btn-primary w-full sm:w-auto">
              Enviar mensaje
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
              </svg>
            </button>

            <!-- Status messages (hidden by default) -->
            <div id="form-success" class="hidden p-4 rounded-xl bg-emerald-50 dark:bg-emerald-900/30 border border-emerald-200 dark:border-emerald-800/50" role="alert">
              <p class="text-sm font-medium text-emerald-700 dark:text-emerald-300">
                ¡Mensaje enviado con éxito! Te responderé a la brevedad.
              </p>
            </div>
            <div id="form-error" class="hidden p-4 rounded-xl bg-rose-50 dark:bg-rose-900/30 border border-rose-200 dark:border-rose-800/50" role="alert">
              <p class="text-sm font-medium text-rose-700 dark:text-rose-300">
                Por favor completa todos los campos requeridos correctamente.
              </p>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    var form    = document.getElementById('contact-form');
    var success = document.getElementById('form-success');
    var error   = document.getElementById('form-error');

    if (!form) return;

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      success.classList.add('hidden');
      error.classList.add('hidden');

      var name    = form.querySelector('#contact-name').value.trim();
      var email   = form.querySelector('#contact-email').value.trim();
      var message = form.querySelector('#contact-message').value.trim();

      /* Basic validation */
      var emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!name || !email || !message || !emailPattern.test(email)) {
        error.classList.remove('hidden');
        error.focus();
        return;
      }

      /*
       * For production, replace this block with a fetch() call to your
       * preferred form backend (Formspree, Netlify Forms, a custom API, etc.)
       */
      success.classList.remove('hidden');
      success.focus();
      form.reset();
    });
  })();
</script>
