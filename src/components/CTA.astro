---
import { cta } from '../data/content';
---

<section class="py-20 md:py-28 relative overflow-hidden" aria-labelledby="cta-heading">
  <!-- Gradient background -->
  <div class="absolute inset-0 bg-gradient-to-br from-petrol-800 via-petrol-700 to-petrol-900 dark:from-petrol-950 dark:via-petrol-900 dark:to-slate-950" aria-hidden="true"></div>

  <!-- Decorative elements -->
  <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
    <div class="absolute -top-24 -right-24 w-96 h-96 rounded-full bg-petrol-600/20 blur-3xl"></div>
    <div class="absolute -bottom-24 -left-24 w-80 h-80 rounded-full bg-petrol-500/15 blur-3xl"></div>
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"></div>
  </div>

  <div class="container-custom relative z-10">
    <div class="max-w-3xl mx-auto text-center">
      <h2
        id="cta-heading"
        data-animate
        class="font-display font-extrabold text-3xl sm:text-4xl lg:text-5xl text-white leading-tight tracking-tight mb-6"
      >
        {cta.headline}
      </h2>

      <p
        data-animate
        class="text-lg text-petrol-200/80 leading-relaxed mb-10"
        style="transition-delay: 100ms;"
      >
        {cta.description}
      </p>

      <div data-animate style="transition-delay: 200ms;">
        <a
          href={cta.button.href}
          class="inline-flex items-center justify-center gap-2
                 px-8 py-4 rounded-xl font-semibold text-base
                 bg-white text-petrol-800 hover:bg-petrol-50
                 shadow-xl shadow-black/20
                 transition-all duration-300 hover:-translate-y-0.5 hover:shadow-2xl active:translate-y-0"
        >
          {cta.button.label}
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
