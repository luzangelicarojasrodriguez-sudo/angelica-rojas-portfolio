---

<section id="especialidades" class="section-padding relative overflow-hidden" aria-labelledby="specialties-heading">
  <!-- Bg accent -->
  <div class="absolute top-0 left-0 right-0 h-px divider-gold" aria-hidden="true"></div>
  <div class="absolute inset-0 -z-10" aria-hidden="true"
       style="background: radial-gradient(ellipse 80% 50% at 50% 100%, rgba(217,119,6,0.04), transparent);"></div>

  <div class="container-custom">
    <!-- Section header -->
    <div data-animate class="text-center mb-14 lg:mb-16">
      <span class="section-label justify-center">Áreas de Expertise</span>
      <h2 id="specialties-heading" class="section-heading">Especialidades que generan impacto</h2>
      <p class="section-subheading mx-auto mt-4">
        Cada servicio combina pensamiento estratégico, experiencia práctica y un enfoque orientado a resultados medibles.
      </p>
    </div>

    <!-- Specialties grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-5">
      {specialties.map((specialty, i) => (
        <article
          data-animate="scale"
          style={`transition-delay: ${i * 60}ms;`}
          class="glass-card glass-card-hover p-6 lg:p-7 group cursor-default"
        >
          <!-- Icon with gold glow -->
          <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-5 flex-shrink-0
                       transition-all duration-200"
               style="background: rgba(217,119,6,0.10); border: 1px solid rgba(217,119,6,0.20);">
            <svg class="w-5 h-5 text-gold-500 group-hover:text-gold-400 transition-colors duration-200"
                 fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[specialty.icon] || iconPaths.strategy} />
            </svg>
          </div>

          <h3 class="font-display font-bold text-lg text-onyx-100 mb-2 leading-snug group-hover:text-onyx-50 transition-colors duration-200">
            {specialty.title}
          </h3>
          <p class="text-sm leading-relaxed text-onyx-500 group-hover:text-onyx-400 transition-colors duration-200">
            {specialty.description}
          </p>

          <!-- Bottom gold accent line on hover -->
          <div class="mt-5 h-px w-0 group-hover:w-full bg-gradient-to-r from-gold-600 to-gold-400
                       transition-all duration-300 ease-out" aria-hidden="true"></div>
        </article>
      ))}
    </div>
  </div>
</section>
