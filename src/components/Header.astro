---
import { navigation, siteConfig } from '../data/content';
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" role="banner">
  <nav class="container-custom flex items-center justify-between h-16 lg:h-20" aria-label="Navegación principal">
    <!-- Logo / Name -->
    <a
      href="#inicio"
      class="font-display font-bold text-xl sm:text-2xl tracking-tight text-onyx-50
             transition-colors duration-200 hover:text-gold-400"
    >
      {siteConfig.name}<span class="text-gold-500">.</span>
    </a>

    <!-- Desktop navigation -->
    <div class="hidden lg:flex items-center gap-1">
      {navigation.map((item) => (
        <a
          href={item.href}
          class="relative px-4 py-2 text-sm font-accent font-medium text-onyx-400
                 hover:text-onyx-50 transition-colors duration-200 group"
        >
          {item.label}
          <span class="absolute bottom-0.5 left-4 right-4 h-px bg-gold-500
                        scale-x-0 group-hover:scale-x-100 origin-left
                        transition-transform duration-250 ease-out" aria-hidden="true"></span>
        </a>
      ))}
      <a
        href="#contacto"
        class="ml-4 btn-primary text-xs px-5 py-2.5"
      >
        Hablemos
      </a>
    </div>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-toggle"
      type="button"
      class="lg:hidden p-2 rounded-lg text-onyx-400 hover:text-onyx-50
             hover:bg-onyx-800/60 transition-colors duration-200"
      aria-label="Abrir menú de navegación"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path id="hamburger-path" stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden lg:hidden border-t border-onyx-800/60"
    style="background: rgba(12,10,9,0.96); backdrop-filter: blur(20px);"
    role="menu"
  >
    <div class="container-custom py-6 flex flex-col gap-1">
      {navigation.map((item) => (
        <a
          href={item.href}
          class="mobile-nav-link px-4 py-3 text-base font-accent font-medium rounded-xl
                 text-onyx-300 hover:text-onyx-50 hover:bg-onyx-800/50
                 transition-all duration-200"
          role="menuitem"
        >
          {item.label}
        </a>
      ))}
      <div class="pt-2">
        <a href="#contacto" class="btn-primary w-full justify-center mobile-nav-link">
          Hablemos
        </a>
      </div>
    </div>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-16 lg:h-20" aria-hidden="true"></div>

<script is:inline>
  (function () {
    var header = document.getElementById('site-header');
    var toggle = document.getElementById('mobile-menu-toggle');
    var menu   = document.getElementById('mobile-menu');
    var path   = document.getElementById('hamburger-path');
    var links  = document.querySelectorAll('.mobile-nav-link');

    var OPEN_D  = 'M6 18L18 6M6 6l12 12';
    var CLOSE_D = 'M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5';

    /* Scroll: enhance glass effect */
    window.addEventListener('scroll', function () {
      if (window.scrollY > 20) {
        header.style.background    = 'rgba(12,10,9,0.85)';
        header.style.backdropFilter = 'blur(24px)';
        header.style.borderBottom  = '1px solid rgba(255,255,255,0.06)';
        header.style.boxShadow     = '0 4px 24px rgba(0,0,0,0.40)';
      } else {
        header.style.background    = 'transparent';
        header.style.backdropFilter = 'none';
        header.style.borderBottom  = 'none';
        header.style.boxShadow     = 'none';
      }
    }, { passive: true });

    /* Mobile menu toggle */
    function closeMenu() {
      menu.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
      path.setAttribute('d', CLOSE_D);
    }

    toggle.addEventListener('click', function () {
      var isOpen = !menu.classList.contains('hidden');
      if (isOpen) {
        closeMenu();
      } else {
        menu.classList.remove('hidden');
        toggle.setAttribute('aria-expanded', 'true');
        path.setAttribute('d', OPEN_D);
      }
    });

    links.forEach(function (link) {
      link.addEventListener('click', closeMenu);
    });
  })();
</script>
