---
import { successStories } from '../data/content';
---

<section id="resultados" class="section-padding relative overflow-hidden" aria-labelledby="success-heading">
  <!-- Full-width dark band with subtle gradient -->
  <div class="absolute inset-0 -z-10"
       style="background: linear-gradient(180deg, rgba(217,119,6,0.04) 0%, transparent 100%);" aria-hidden="true"></div>
  <div class="absolute top-0 left-0 right-0 h-px divider-gold" aria-hidden="true"></div>
  <div class="absolute bottom-0 left-0 right-0 h-px divider-gold" aria-hidden="true"></div>

  <div class="container-custom">
    <!-- Header -->
    <div data-animate class="text-center mb-14 lg:mb-16">
      <span class="section-label justify-center">Resultados</span>
      <h2 id="success-heading" class="section-heading">Casos de éxito con impacto medible</h2>
      <p class="section-subheading mx-auto mt-4">
        Resultados cuantificables que demuestran el poder de una comunicación estratégica bien ejecutada.
      </p>
    </div>

    <!-- Success stories — large number display -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-px"
         style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.06); border-radius: 20px; overflow: hidden;">
      {successStories.map((story, i) => (
        <article
          data-animate="scale"
          style={`transition-delay: ${i * 80}ms;`}
          class="p-8 lg:p-10 text-center group cursor-default relative"
          style={`background: rgba(12,10,9,0.70); transition-delay: ${i * 80}ms;`}
        >
          <!-- Hover bg -->
          <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"
               style="background: rgba(217,119,6,0.04);"></div>

          <!-- Huge metric -->
          <p class="font-display font-bold text-5xl lg:text-6xl gradient-text mb-3
                     transition-transform duration-200 group-hover:scale-105 relative z-10">
            {story.metric}
          </p>

          <!-- Title -->
          <h3 class="font-display font-semibold text-lg text-onyx-100 mb-3 relative z-10">
            {story.title}
          </h3>

          <!-- Description -->
          <p class="text-sm text-onyx-500 leading-relaxed mb-5 relative z-10">
            {story.description}
          </p>

          <!-- Context pill -->
          <span class="badge-gold text-[10px] relative z-10">{story.context}</span>

          <!-- Separator (right border, hidden on last) -->
          {i < successStories.length - 1 && (
            <div class="absolute top-8 right-0 bottom-8 w-px"
                 style="background: rgba(255,255,255,0.05);" aria-hidden="true"></div>
          )}
        </article>
      ))}
    </div>
  </div>
</section>
