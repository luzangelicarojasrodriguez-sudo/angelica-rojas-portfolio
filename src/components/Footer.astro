---

<footer role="contentinfo" style="border-top: 1px solid rgba(255,255,255,0.07);">
  <div class="container-custom">
    <!-- Main footer content -->
    <div class="py-12 lg:py-16 grid sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8">

      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="#inicio"
           class="font-display font-bold text-2xl text-onyx-50 tracking-tight hover:text-gold-400 transition-colors duration-200 inline-block mb-3">
          {siteConfig.name}<span class="text-gold-500">.</span>
        </a>
        <p class="text-sm text-onyx-500 leading-relaxed max-w-xs">
          {siteConfig.tagline}
        </p>
      </div>

      <!-- Quick links -->
      <div>
        <h3 class="font-accent font-semibold text-xs uppercase tracking-[0.15em] text-onyx-500 mb-5">Navegación</h3>
        <ul class="space-y-3">
          {navigation.map((item) => (
            <li>
              <a href={item.href}
                 class="text-sm text-onyx-400 hover:text-gold-400 transition-colors duration-200 font-accent">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-accent font-semibold text-xs uppercase tracking-[0.15em] text-onyx-500 mb-5">Contacto</h3>
        <ul class="space-y-3">
          <li>
            <a href={`mailto:${siteConfig.email}`}
               class="text-sm text-onyx-400 hover:text-gold-400 transition-colors duration-200 font-accent break-all">
              {siteConfig.email}
            </a>
          </li>
          <li>
            <a href={`tel:${siteConfig.phone}`}
               class="text-sm text-onyx-400 hover:text-gold-400 transition-colors duration-200 font-accent">
              {siteConfig.phone}
            </a>
          </li>
          <li>
            <span class="text-sm text-onyx-500 font-accent">{siteConfig.location}</span>
          </li>
        </ul>
      </div>

      <!-- Social + CV -->
      <div>
        <h3 class="font-accent font-semibold text-xs uppercase tracking-[0.15em] text-onyx-500 mb-5">Redes</h3>
        <div class="flex gap-2.5 mb-6">
          {socialLinks.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`Visitar perfil en ${link.label}`}
              class="w-9 h-9 rounded-lg flex items-center justify-center
                     text-onyx-500 hover:text-gold-400
                     transition-all duration-200"
              style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.08);"
              onmouseover="this.style.borderColor='rgba(217,119,6,0.30)'; this.style.background='rgba(217,119,6,0.08)';"
              onmouseout="this.style.borderColor='rgba(255,255,255,0.08)'; this.style.background='rgba(255,255,255,0.06)';"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d={socialIcons[link.name] || ''} />
              </svg>
            </a>
          ))}
        </div>
        <a
          href="/cv-angelica-rojas.pdf"
          download
          class="inline-flex items-center gap-2 text-sm font-accent font-semibold text-gold-500
                 hover:text-gold-400 transition-colors duration-200 cursor-pointer"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12M12 16.5V3" />
          </svg>
          Descargar CV
        </a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="py-6 flex flex-col sm:flex-row items-center justify-between gap-3"
         style="border-top: 1px solid rgba(255,255,255,0.06);">
      <p class="text-xs text-onyx-600 font-accent">
        &copy; {currentYear} {siteConfig.name}. Todos los derechos reservados.
      </p>
      <p class="text-xs text-onyx-700 font-accent">
        Diseñado con estrategia y pasión.
      </p>
    </div>
  </div>
</footer>
